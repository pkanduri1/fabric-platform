<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- Issue #27: Create SOURCE_SYSTEMS table for write operations.
         GET paths use SOURCE_CONFIG (exists). Write paths (add/update/disable/enable)
         use SOURCE_SYSTEMS which was missing from the schema. -->
    <changeSet id="us027-001-create-source-systems" author="claude">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="SOURCE_SYSTEMS" schemaName="CM3INT"/>
            </not>
        </preConditions>
        <createTable tableName="SOURCE_SYSTEMS" schemaName="CM3INT">
            <column name="ID" type="VARCHAR2(50)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_SOURCE_SYSTEMS"/>
            </column>
            <column name="NAME" type="VARCHAR2(100)">
                <constraints nullable="false"/>
            </column>
            <column name="TYPE" type="VARCHAR2(20)">
                <constraints nullable="false"/>
            </column>
            <column name="DESCRIPTION" type="VARCHAR2(500)"/>
            <column name="CONNECTION_STRING" type="VARCHAR2(1000)"/>
            <column name="ENABLED" type="CHAR(1)" defaultValue="Y">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_DATE" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="JOB_COUNT" type="NUMBER(10)" defaultValueNumeric="0"/>
        </createTable>
        <rollback>
            <dropTable tableName="SOURCE_SYSTEMS" schemaName="CM3INT"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
